// 显示结果弹窗
function showResultModal(data, lng, lat, address) {
    const modalBody = document.getElementById('modalBody');
    
    // 构建基本信息
    let html = `
        <div class="result-info">
            <p><strong>经纬度：</strong>${lng}, ${lat}</p>
            <p><strong>地址：</strong>${address}</p>
            <p><strong>席位数量：</strong>共找到 ${data.length} 个可用席位</p>
        </div>
    `;
    
    // 构建每个席位卡片
    data.forEach((item, index) => {
        const imagingMode = item['05-ImagingMode'] 
            ? (Array.isArray(item['05-ImagingMode']) ? item['05-ImagingMode'].join('、') : item['05-ImagingMode'])
            : '未知';
            
        html += `
            <div class="seat-card">
                <h3>🛰️ 席位 ${index + 1}</h3>
                <div class="info-row">
                    <span class="info-label">卫星名称：</span>
                    <span class="info-value">${item['01-SourceName'] || '未知'}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">中心时间：</span>
                    <span class="info-value highlight">${item['04-CentralityTime'] || '未知'}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">成像模式：</span>
                    <span class="info-value">${imagingMode}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">侧摆位置：</span>
                    <span class="info-value">${item['06-RollPosition'] || '未知'}</span>
                </div>
                <div class="task-submit-box">
                    <button class="btn btn-submit-task" data-index="${index}">
                        🚀 提交成像任务
                    </button>
                </div>
            </div>
        `;
    });
    
    modalBody.innerHTML = html;
    document.getElementById('resultModal').style.display = 'block';
    
    // 等待DOM更新后再绑定事件
    setTimeout(() => {
        // 为所有提交按钮绑定事件
        const submitButtons = document.querySelectorAll('.btn-submit-task');
        console.log('找到提交按钮数量：', submitButtons.length);
        console.log('按钮元素：', submitButtons);
        
        submitButtons.forEach((button, index) => {
            console.log(`绑定第 ${index + 1} 个按钮的点击事件`);
            
            // 测试按钮是否可点击
            button.onclick = function(e) {
                console.log(`点击了第 ${index + 1} 个按钮`);
                console.log('事件对象：', e);
                console.log('按钮数据：', data[index]);
                submitTask(data[index]);
            };
            
            // 添加鼠标悬停测试
            button.onmouseenter = function() {
                console.log(`鼠标进入第 ${index + 1} 个按钮`);
            };
        });
    }, 100);
}

// 显示无结果弹窗
function showNoResultModal() {
    const modalBody = document.getElementById('modalBody');
    modalBody.innerHTML = `
        <div class="no-result">
            <div class="no-result-icon">🔍</div>
            <p style="font-size: 16px; color: #666;">未找到可用的席位时间</p>
            <p style="font-size: 14px; color: #999; margin-top: 10px;">请尝试选择其他位置</p>
        </div>
    `;
    document.getElementById('resultModal').style.display = 'block';
}

// 关闭弹窗
function closeModal() {
    document.getElementById('resultModal').style.display = 'none';
}

// 点击弹窗外部关闭
window.onclick = function(event) {
    const modal = document.getElementById('resultModal');
    if (event.target === modal) {
        closeModal();
    }
}

// 提交成像任务
async function submitTask(seatData) {
    // 获取数据
    const lng = seatData['02-Longitude'];
    const lat = seatData['03-Latitude'];
    const centralityTime = seatData['04-CentralityTime'];
    
    // 处理成像模式（取第一个）
    let imagingMode = '';
    if (Array.isArray(seatData['05-ImagingMode'])) {
        imagingMode = seatData['05-ImagingMode'][0];
    } else {
        imagingMode = seatData['05-ImagingMode'] || '未知';
    }
    
    // 确认对话框
    const confirmed = confirm(
        `确认提交成像任务？\n\n` +
        `卫星名称：${seatData['01-SourceName']}\n` +
        `成像时间：${centralityTime}\n` +
        `成像模式：${imagingMode}\n` +
        `目标位置：${lng}, ${lat}\n\n` +
        `点击"确定"提交任务`
    );
    
    if (!confirmed) return;
    
    try {
        // 构建请求URL
        const apiUrl = `http://103.38.224.91:9608?` +
            `Longitude=${lng}&` +
            `Latitude=${lat}&` +
            `CentralityTime=${encodeURIComponent(centralityTime)}&` +
            `ImagingMode=${encodeURIComponent(imagingMode)}`;
        
        console.log("提交任务接口：", apiUrl);
        console.log("提交参数：", {
            Longitude: lng,
            Latitude: lat,
            CentralityTime: centralityTime,
            ImagingMode: imagingMode
        });
        
        // 调用接口
        const response = await fetch(apiUrl, {
            method: 'GET',
            mode: 'cors'
        });
        
        if (!response.ok) {
            throw new Error(`HTTP错误: ${response.status}`);
        }
        
        const result = await response.json();
        console.log("任务提交结果：", result);
        
        // 检查结果
        if (result['04-ConditionCode'] === 1) {
            // 成功
            alert(
                `✅ 任务提交成功！\n\n` +
                `卫星名称：${result['01-SourceName']}\n` +
                `成像时间：${result['02-CentralityTime']}\n` +
                `成像模式：${getModeText(result['03-ImagingMode'])}\n` +
                `任务状态：规划成功\n\n` +
                `请等待卫星拍摄，稍后可查看成像结果。`
            );
        } else {
            // 失败
            alert(
                `❌ 任务规划失败\n\n` +
                `可能原因：\n` +
                `1. 该时间段已被占用\n` +
                `2. 卫星资源不足\n` +
                `3. 天气条件不满足\n` +
                `4. 目标位置超出卫星覆盖范围\n\n` +
                `建议选择其他席位重试。`
            );
        }
        
    } catch (error) {
        console.error("任务提交失败：", error);
        alert(
            `任务提交失败：${error.message}\n\n` +
            `可能原因：\n` +
            `1. 网络连接问题\n` +
            `2. 接口服务未启动（9608端口）\n` +
            `3. 跨域限制（需要后端配置CORS）\n\n` +
            `请检查网络连接或联系技术支持。`
        );
    }
}

// 成像模式代码转文字
function getModeText(code) {
    const modes = {
        '1': '条带模式',
        '2': '滑聚模式',
        '3': '聚束模式'
    };
    return modes[String(code)] || '未知模式';
}

window.onload = init;

