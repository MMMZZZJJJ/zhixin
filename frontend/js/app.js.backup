let map, marker;

// 初始化地图
function init() {
    // 使用高德地图瓦片 (还原原站视觉)
    // 注意：高德瓦片在中国境内有偏移，但作为复刻版，我们保持与原站一致的视觉体验
    map = L.map('map', {
        zoomControl: false,
        attributionControl: false
    }).setView([39.914885, 116.403874], 10);

    L.tileLayer('https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}', {
        subdomains: ['1', '2', '3', '4'],
        maxZoom: 18
    }).addTo(map);

    L.control.zoom({ position: 'bottomright' }).addTo(map);

    // 地图点击事件
    map.on('click', function(e) {
        updateData(e.latlng.lat, e.latlng.lng);
    });
}

// 更新数据逻辑
async function updateData(lat, lng) {
    lat = parseFloat(lat).toFixed(6);
    lng = parseFloat(lng).toFixed(6);

    // 1. 更新输入框
    document.getElementById('lat_input').value = lat;
    document.getElementById('lng_input').value = lng;

    // 2. 更新标记
    if (marker) map.removeLayer(marker);
    marker = L.marker([lat, lng]).addTo(map);
    map.panTo([lat, lng]);

    // 3. 填充表格基础信息
    document.getElementById('res_pos').innerText = `${lng}, ${lat}`;
    document.getElementById('res_deg').innerText = `${lng}°, ${lat}°`;
    document.getElementById('res_dms').innerText = `${toDMS(lng, 'lng')}, ${toDMS(lat, 'lat')}`;

    // 4. 逆地理编码查询 (中文)
    document.getElementById('res_country').innerText = "查询中...";
    document.getElementById('res_addr').innerText = "正在获取详细地址...";

    try {
        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1&accept-language=zh-CN`);
        const data = await response.json();
        
        if (data && data.address) {
            const country = data.address.country || "未知";
            const fullAddr = data.display_name || "未知位置";
            document.getElementById('res_country').innerText = country;
            document.getElementById('res_addr').innerText = fullAddr;
        } else {
            document.getElementById('res_country').innerText = "公海/无人区";
            document.getElementById('res_addr').innerText = "无法获取详细地址";
        }
    } catch (e) {
        document.getElementById('res_country').innerText = "查询失败";
        document.getElementById('res_addr').innerText = "网络异常，请稍后再试";
    }
}

// 度分秒转换逻辑
function toDMS(val, type) {
    const abs = Math.abs(val);
    const d = Math.floor(abs);
    const m = Math.floor((abs - d) * 60);
    const s = ((abs - d - m / 60) * 3600).toFixed(2);
    let suffix = "";
    if (type === 'lng') {
        suffix = val >= 0 ? "东经E" : "西经W";
    } else {
        suffix = val >= 0 ? "北纬N" : "南纬S";
    }
    return `${d}°${m}′${s}″ ${suffix}`;
}

// 手动输入定位
function manualLocate() {
    const lat = document.getElementById('lat_input').value;
    const lng = document.getElementById('lng_input').value;
    if (lat && lng) {
        map.setZoom(15);
        updateData(lat, lng);
    } else {
        alert("请输入完整的经纬度数值");
    }
}

// 重置
function resetAll() {
    document.getElementById('lat_input').value = '';
    document.getElementById('lng_input').value = '';
    document.getElementById('res_pos').innerText = '点击地图获取';
    document.getElementById('res_country').innerText = '--';
    document.getElementById('res_addr').innerText = '--';
    document.getElementById('res_deg').innerText = '--';
    document.getElementById('res_dms').innerText = '--';
    if (marker) map.removeLayer(marker);
    map.setView([39.914885, 116.403874], 10);
}

// 下单 - 调用席位时间预测接口
async function placeOrder() {
    const lat = document.getElementById('lat_input').value;
    const lng = document.getElementById('lng_input').value;
    const address = document.getElementById('res_addr').innerText;
    
    if (!lat || !lng || address === '--' || address === '点击地图获取') {
        alert("请先选择或输入有效的经纬度位置");
        return;
    }
    
    // 精度检查和警告
    const lngPrecision = getDecimalPlaces(lng);
    const latPrecision = getDecimalPlaces(lat);
    
    if (lngPrecision < 4 || latPrecision < 4) {
        const confirmed = confirm(
            `⚠️ 精度警告\n\n` +
            `当前经纬度精度较低：\n` +
            `经度：${lngPrecision}位小数（约${getPrecisionDistance(lngPrecision)}误差）\n` +
            `纬度：${latPrecision}位小数（约${getPrecisionDistance(latPrecision)}误差）\n\n` +
            `建议使用至少4位小数（约11米精度）\n` +
            `推荐使用6位小数（约0.11米精度）\n\n` +
            `是否继续查询？`
        );
        if (!confirmed) return;
    }
    
    // 显示加载状态
    const btnOrder = document.querySelector('.btn-order');
    const originalText = btnOrder.innerText;
    btnOrder.innerText = '预测中...';
    btnOrder.disabled = true;
    
    try {
        // 调用席位时间预测接口
        const apiUrl = `http://103.38.224.91:9069?Longitude=${lng}&Latitude=${lat}`;
        console.log("请求接口：", apiUrl);
        console.log("经度精度：", lngPrecision, "位小数");
        console.log("纬度精度：", latPrecision, "位小数");
        
        const response = await fetch(apiUrl, {
            method: 'GET',
            mode: 'cors'
        });
        
        if (!response.ok) {
            throw new Error(`HTTP错误: ${response.status}`);
        }
        
        const data = await response.json();
        console.log("接口返回数据：", data);
        
        // 解析返回数据并显示
        if (data && data.length > 0) {
            showResultModal(data, lng, lat, address);
        } else {
            showNoResultModal();
        }
        
    } catch (error) {
        console.error("接口调用失败：", error);
        alert(`预测失败：${error.message}\n\n可能原因：\n1. 网络连接问题\n2. 接口服务未启动\n3. 跨域限制（需要后端配置CORS）`);
    } finally {
        // 恢复按钮状态
        btnOrder.innerText = originalText;
        btnOrder.disabled = false;
    }
}

// 获取小数位数
function getDecimalPlaces(num) {
    const str = String(num);
    if (str.indexOf('.') === -1) return 0;
    return str.split('.')[1].length;
}

// 获取精度对应的距离描述
function getPrecisionDistance(places) {
    const distances = {
        0: '约111公里',
        1: '约11.1公里',
        2: '约1.11公里',
        3: '约111米',
        4: '约11.1米',
        5: '约1.11米',
        6: '约0.11米'
    };
    return distances[places] || '未知';
}

