<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>智星空间</title>
    
    <!-- 引入开源地图库 -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- 引入自定义样式 -->
    <link rel="stylesheet" href="../css/index.css" />
</head>
<body>

<div class="header">
    <h1>智星空间天地一体化综合服务平台</h1>
</div>

<div class="main-container">
    <!-- 地图区域 -->
    <div id="map"></div>

    <!-- 操作面板 -->
    <div class="side-panel">
        <div class="form-group">
            <label>经度 (东经E 西经W)</label>
            <input type="text" id="lng_input" placeholder="如：116.403874">
        </div>
        <div class="form-group">
            <label>纬度 (北纬N 南纬S)</label>
            <input type="text" id="lat_input" placeholder="如：39.914885">
        </div>

        <div class="btn-box">
            <button class="btn btn-locate" onclick="manualLocate()">定位到该经纬度</button>
            <button class="btn btn-clear" onclick="resetAll()">清空</button>
        </div>

        <div class="btn-box">
            <button class="btn btn-order" onclick="placeOrder()">下单</button>
        </div>

        <div class="btn-box">
            <button class="btn btn-test" onclick="testModal()">🧪 模拟测试</button>
        </div>

        <table class="result-table">
            <tr>
                <td class="td-label">经纬度</td>
                <td class="td-value" id="res_pos">点击地图获取</td>
            </tr>
            <tr>
                <td class="td-label">所属国家/地区</td>
                <td class="td-value highlight" id="res_country">--</td>
            </tr>
            <tr>
                <td class="td-label">详细地址</td>
                <td class="td-value" id="res_addr">--</td>
            </tr>
            <tr>
                <td class="td-label">度格式</td>
                <td class="td-value" id="res_deg">--</td>
            </tr>
            <tr>
                <td class="td-label">度分秒格式</td>
                <td class="td-value" id="res_dms">--</td>
            </tr>
        </table>

        <div style="margin-top: 20px; font-size: 12px; color: #999; line-height: 1.8;">
            <p>使用说明：</p>
            <p>1. 在地图上点击，可自动获取该位置经纬度及地址。</p>
            <p>2. 输入经纬度点击定位，可快速在地图上找点。</p>
            <p style="color: #00d4ff; margin-top: 10px;">💡 精度建议：建议使用至少4位小数（约11米精度），推荐6位小数（约0.11米精度）</p>
        </div>
    </div>
</div>

<!-- 自定义结果弹窗 -->
<div id="resultModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>席位时间预测结果</h2>
            <span class="close" onclick="closeModal()">&times;</span>
        </div>
        <div class="modal-body" id="modalBody">
            <!-- 动态内容 -->
        </div>
        <div class="modal-footer">
            <button class="btn btn-locate" onclick="closeModal()">关闭</button>
        </div>
    </div>
</div>

<!-- 确认提交弹窗 -->
<div id="confirmModal" class="modal">
    <div class="modal-content confirm-modal-content">
        <div class="modal-header">
            <h2>🚀 确认提交成像任务</h2>
            <span class="close" onclick="closeConfirmModal()">&times;</span>
        </div>
        <div class="modal-body confirm-modal-body" id="confirmModalBody">
            <!-- 动态内容 -->
        </div>
        <div class="modal-footer">
            <button class="btn btn-cancel" onclick="closeConfirmModal()">取消</button>
            <button class="btn btn-confirm" id="confirmSubmitBtn">确定提交</button>
        </div>
    </div>
</div>

<!-- 引入自定义脚本 -->
<script src="../js/app.js"></script>

</body>
</html>
